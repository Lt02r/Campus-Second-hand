.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}
.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
}
.app-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #1E90FF;
  margin-bottom: 10rpx;
}
.app-desc {
  font-size: 26rpx;
  color: #999;
}
.wx-login-btn {
  background: #07c160;
  color: #fff;
  width: 600rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  border: none;
}
.wx-login-btn::after { border: none; }
.bind-header {
  width: 100%;
  margin-bottom: 40rpx;
}
.bind-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}
.bind-desc {
  font-size: 26rpx;
  color: #999;
}
.form-group {
  width: 100%;
  margin-bottom: 30rpx;
}
.form-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}
.form-input {
  background: #fff;
  border-radius: 8rpx;
  padding: 0 20rpx;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}
.form-picker {
  background: #fff;
  border-radius: 8rpx;
  padding: 0 20rpx;
  height: 80rpx;
  line-height: 80rpx;
  box-sizing:  border-box;
  font-size: 30rpx;
  color: #333;
}
.bind-btn {
  background: #1E90FF;
  color: #fff;
  width: 100%;
  border-radius: 50rpx;
  font-size: 32rpx;
  border: none;
  margin-top: 20rpx;
}
.bind-btn::after { border: none; }
.bind-note {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  display: block;
}
