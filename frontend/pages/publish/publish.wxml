<view class="container">
  <view class="form-group">
    <text class="form-label">物品名称 <text class="required">*</text></text>
    <input class="form-input" placeholder="请输入物品名称（最多50字）" maxlength="50" value="{{title}}" bindinput="onTitleInput" />
  </view>

  <view class="form-group">
    <text class="form-label">商品分类 <text class="required">*</text></text>
    <picker mode="selector" range="{{categories}}" range-key="label" value="{{categoryIndex}}" bindchange="onCategoryChange">
      <view class="form-picker">{{categories[categoryIndex].label}} ▾</view>
    </picker>
  </view>

  <view class="form-group">
    <text class="form-label">价格（元）<text class="required">*</text></text>
    <input class="form-input" type="digit" placeholder="请输入价格" value="{{price}}" bindinput="onPriceInput" />
  </view>

  <view class="form-group">
    <text class="form-label">商品描述</text>
    <textarea class="form-textarea" placeholder="请描述物品成色、品牌等信息..." value="{{description}}" bindinput="onDescInput" maxlength="500" />
  </view>

  <view class="form-group">
    <text class="form-label">交易地点</text>
    <picker mode="selector" range="{{locations}}" value="{{locationIndex}}" bindchange="onLocationChange">
      <view class="form-picker">{{locations[locationIndex]}} ▾</view>
    </picker>
  </view>

  <view class="form-group">
    <text class="form-label">物品图片（最多3张）<text class="required">*</text></text>
    <view class="image-list">
      <view class="image-item"wx:if="{{images && images.length}}" wx:for="{{images}}" wx:key="index">
        <image class="preview-img" src="{{item}}" mode="aspectFill" />
        <view class="img-delete" bindtap="removeImage" data-index="{{index}}">×</view>
      </view>
      <view class="image-add" bindtap="onChooseImage" wx:if="{{images.length < 3}}">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>

  <button class="submit-btn" bindtap="onSubmit" loading="{{loading}}" disabled="{{loading}}">
    {{editId ? '保存修改' : '发布物品'}}
  </button>
</view>
