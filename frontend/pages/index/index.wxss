.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 50rpx;
  padding: 10rpx 20rpx;
  margin-bottom: 20rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
}
.search-btn {
  background: #1E90FF;
  color: #fff;
  font-size: 26rpx;
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  border: none;
  line-height: 1.6;
}
.search-btn::after { border: none; }
.filter-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}
.filter-btn {
  background: #fff;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #666;
}
.price-filter {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}
.price-input {
  flex: 1;
  background: #fff;
  border-radius: 8rpx;
  padding: 12rpx;
  font-size: 26rpx;
  text-align: center;
}
.price-sep { color: #999; }
.filter-search-btn {
  background: #1E90FF;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  border: none;
  line-height: 1.6;
}
.filter-search-btn::after { border: none; }
.item-list { }
.item-card {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.item-img {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
}
.item-info {
  flex: 1;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.item-meta {
  display: flex;
  gap: 10rpx;
  margin-top: 8rpx;
}
.item-category {
  background: #fef0f0;
  color: #1E90FF;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}
.item-college {
  color: #999;
  font-size: 22rpx;
}
.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.item-price {
  color: #1E90FF;
  font-size: 32rpx;
  font-weight: bold;
}
.item-location {
  color: #999;
  font-size: 22rpx;
}
.loading-tip, .empty-tip, .no-more {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 30rpx 0;
}
