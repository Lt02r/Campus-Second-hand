.swiper {
  width: 100%;
  height: 500rpx;
}
.swiper-img {
  width: 100%;
  height: 500rpx;
}
.item-card {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.item-price {
  font-size: 48rpx;
  color: #1E90FF;
  font-weight: bold;
}
.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
}
.status-available { background: #e8f5e9; color: #2e7d32; }
.status-traded { background: #e3f2fd; color: #1565c0; }
.status-offline { background: #f5f5f5; color: #999; }
.item-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}
.item-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.tag-category {
  background: #fef0f0;
  color: #1E90FF;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}
.tag-location {
  color: #666;
  font-size: 26rpx;
}
.item-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}
.seller-card {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.seller-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.seller-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}
.seller-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}
.seller-college {
  font-size: 26rpx;
  color: #999;
  display: block;
}
.owner-actions {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  background: #fff;
  margin-bottom: 16rpx;
}
.action-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  border: none;
  line-height: 1.4;
}
.action-btn::after { border: none; }
.btn-edit { background: #f5f5f5; color: #333; }
.btn-traded { background: #e3f2fd; color: #1565c0; }
.btn-offline { background: #fef0f0; color: #e64340; }
.btn-online { background: #e8f5e9; color: #2e7d32; }
.messages-section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 120rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}
.message-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.msg-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}
.msg-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}
.msg-college {
  font-size: 22rpx;
  color: #999;
}
.msg-text {
  font-size: 28rpx;
  color: #333;
  display: block;
  line-height: 1.5;
}
.msg-time {
  font-size: 22rpx;
  color: #ccc;
  display: block;
  margin-top: 6rpx;
}
.no-message {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}
.message-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 20rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
  gap: 16rpx;
}
.msg-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}
.send-btn {
  background: #e64340;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border: none;
  line-height: 1.4;
}
.send-btn::after { border: none; }
